# ── Surf AI 인증 ─────────────────────────────────────────
# jwt.txt 파일에 JWT 토큰 저장 (이 파일에는 불필요)

# 브라우저 F12 → Network → 아무 요청 → x-device-id 헤더값 복사
DEVICE_ID=0915959b-8945-46e3-bf0a-dfeeec441575

# ── Gemini API ───────────────────────────────────────────
# https://aistudio.google.com/app/apikey 에서 발급
GEMINI_API_KEY=your_gemini_api_key_here

# ── CryptoPanic (선택) ───────────────────────────────────
# https://cryptopanic.com/developers/api/ 에서 발급 (무료)
# 없어도 동작하나, 있으면 뉴스 품질 향상
CRYPTOPANIC_TOKEN=
